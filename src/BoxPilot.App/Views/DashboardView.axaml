<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BoxPilot.App.ViewModels"
             x:Class="BoxPilot.App.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">
  <Grid RowDefinitions="Auto,24,210,16,*">
    <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="20">
      <TextBlock Text="{DynamicResource NavDashboard}" Classes="page-title"
                 VerticalAlignment="Bottom" />
      <Border Grid.Column="1" Classes="soft-panel" Padding="5,3"
              VerticalAlignment="Bottom" Margin="0,0,0,2">
        <StackPanel Orientation="Horizontal" Spacing="3">
          <RadioButton GroupName="RoutingMode" Content="{DynamicResource RuleMode}"
                       IsChecked="{Binding IsRuleMode, Mode=OneWay}"
                       IsEnabled="{Binding Session.CanChangeRoutingMode}"
                       Command="{Binding SetRoutingModeCommand}" CommandParameter="Rule" />
          <RadioButton GroupName="RoutingMode" Content="{DynamicResource GlobalMode}"
                       IsChecked="{Binding IsGlobalMode, Mode=OneWay}"
                       IsEnabled="{Binding Session.CanChangeRoutingMode}"
                       Command="{Binding SetRoutingModeCommand}" CommandParameter="Global" />
          <RadioButton GroupName="RoutingMode" Content="{DynamicResource DirectMode}"
                       IsChecked="{Binding IsDirectMode, Mode=OneWay}"
                       IsEnabled="{Binding Session.CanChangeRoutingMode}"
                       Command="{Binding SetRoutingModeCommand}" CommandParameter="Direct" />
        </StackPanel>
      </Border>
      <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="9"
                  VerticalAlignment="Bottom" Margin="0,0,0,2">
        <Button Classes="ghost" Content="{DynamicResource Restart}"
                Command="{Binding RestartCommand}" IsEnabled="{Binding Session.CanStopCore}"
                IsVisible="{Binding Session.IsCoreRunning}" />
        <Button Classes="danger" Content="{DynamicResource Stop}"
                Command="{Binding StopCommand}" IsEnabled="{Binding Session.CanStopCore}"
                IsVisible="{Binding Session.IsCoreRunning}" />
        <Button Classes="primary" Content="{DynamicResource Start}"
                Command="{Binding StartCommand}" IsEnabled="{Binding Session.CanStartCore}"
                IsVisible="{Binding !Session.IsCoreRunning}" />
      </StackPanel>
    </Grid>

    <Grid Grid.Row="2" ColumnDefinitions="1.35*,0.85*" ColumnSpacing="16">
      <Border Classes="panel">
        <Grid RowDefinitions="Auto,*,Auto">
          <TextBlock Text="{DynamicResource ActiveProfile}" Classes="muted" FontSize="13" />
          <StackPanel Grid.Row="1" VerticalAlignment="Center" Spacing="7">
            <TextBlock Text="{Binding Session.SelectedProfile.Name, FallbackValue=—}"
                       Classes="metric" TextTrimming="CharacterEllipsis" />
            <TextBlock Text="{Binding Session.SelectedProfile.UpdatedAtLocal,
                             StringFormat='{}{0:yyyy-MM-dd · HH:mm}'}"
                       Classes="muted" FontSize="13" />
          </StackPanel>
          <Grid Grid.Row="2" ColumnDefinitions="*,1,*,1,*" ColumnSpacing="16">
            <StackPanel Spacing="3">
              <TextBlock Text="{DynamicResource ProxyNodes}" Classes="muted" FontSize="13" />
              <TextBlock Text="{Binding Session.ActiveNodeDisplay}" FontSize="16" FontWeight="SemiBold" />
            </StackPanel>
            <Border Grid.Column="1" Background="{DynamicResource CardBorderBrush}" />
            <StackPanel Grid.Column="2" Spacing="3">
              <TextBlock Text="{DynamicResource Download}" Classes="muted" FontSize="13" />
              <TextBlock Text="{Binding Session.DownloadRate}" FontSize="16" FontWeight="SemiBold" />
            </StackPanel>
            <Border Grid.Column="3" Background="{DynamicResource CardBorderBrush}" />
            <StackPanel Grid.Column="4" Spacing="3">
              <TextBlock Text="{DynamicResource Upload}" Classes="muted" FontSize="13" />
              <TextBlock Text="{Binding Session.UploadRate}" FontSize="16" FontWeight="SemiBold" />
            </StackPanel>
          </Grid>
        </Grid>
      </Border>

      <Border Grid.Column="1" Classes="dark-panel">
        <Grid RowDefinitions="Auto,*,1,Auto">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="{DynamicResource Status}" Classes="dark-muted" FontSize="13" />
            <Grid Grid.Column="1" Width="7" Height="7" VerticalAlignment="Center">
              <Ellipse Fill="{DynamicResource DarkMutedBrush}" Opacity="0.5" />
              <Ellipse Fill="{DynamicResource SuccessBrush}"
                       IsVisible="{Binding Session.IsCoreRunning}" />
            </Grid>
          </Grid>
          <TextBlock Grid.Row="1" Text="{Binding Session.CoreStateDisplay}" Classes="on-dark"
                     FontSize="28" FontWeight="SemiBold" VerticalAlignment="Center" />
          <Border Grid.Row="2" Background="#28FFFFFF" />
          <Grid Grid.Row="3" ColumnDefinitions="*,*,*" ColumnSpacing="12" Margin="0,14,0,0">
            <StackPanel Spacing="3">
              <TextBlock Text="{DynamicResource Version}" Classes="dark-muted" FontSize="13" />
              <TextBlock Text="{Binding Session.CoreVersion}" Classes="on-dark" FontSize="14" />
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="3">
              <TextBlock Text="{DynamicResource MixedProxy}" Classes="dark-muted" FontSize="13" />
              <TextBlock Text="{Binding Session.Settings.MixedPort}" Classes="on-dark" FontSize="14" />
            </StackPanel>
            <StackPanel Grid.Column="2" Spacing="3">
              <TextBlock Text="TUN" Classes="dark-muted" FontSize="13" />
              <TextBlock Text="{Binding Session.TunDisplay}" Classes="on-dark" FontSize="14" />
            </StackPanel>
          </Grid>
        </Grid>
      </Border>
    </Grid>

    <Border Grid.Row="4" Classes="panel" Padding="0">
      <Grid ColumnDefinitions="236,1,*">
        <Grid RowDefinitions="64,1,*">
          <Grid Margin="18,0" ColumnDefinitions="*,Auto" VerticalAlignment="Center">
            <TextBlock Text="{DynamicResource PolicyGroups}" Classes="section-title" />
            <TextBlock Grid.Column="1" Text="{Binding GroupCountDisplay}"
                       Classes="faint" FontSize="13" />
          </Grid>
          <Border Grid.Row="1" Background="{DynamicResource CardBorderBrush}" />
          <Grid Grid.Row="2">
            <ListBox Classes="proxy-groups" ItemsSource="{Binding ProxyGroups}"
                     SelectedItem="{Binding SelectedGroup}"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:ProxyGroupItemViewModel">
                  <Grid Margin="11,7" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <StackPanel Spacing="3">
                      <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"
                                 TextTrimming="CharacterEllipsis" />
                      <TextBlock Text="{Binding SelectionDisplay}" Classes="muted" FontSize="13"
                                 TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding CountDisplay}"
                               Classes="faint" FontSize="13" VerticalAlignment="Center" />
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
            <TextBlock Text="{DynamicResource NoProxyGroups}" Classes="muted"
                       Margin="18" TextWrapping="Wrap" TextAlignment="Center"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       IsVisible="{Binding !HasProxyGroups}" />
          </Grid>
        </Grid>

        <Border Grid.Column="1" Background="{DynamicResource CardBorderBrush}" />

        <Grid Grid.Column="2" RowDefinitions="96,1,*">
          <Grid Margin="18,12" RowDefinitions="Auto,8,Auto">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="9">
              <StackPanel Spacing="2">
                <TextBlock Text="{Binding SelectedGroup.Name, FallbackValue=—}"
                           Classes="section-title" TextTrimming="CharacterEllipsis" />
                <TextBlock Text="{Binding SelectedGroup.SelectionDisplay, FallbackValue=—}"
                           Classes="muted" FontSize="13" TextTrimming="CharacterEllipsis" />
              </StackPanel>
              <Button Grid.Column="1" Classes="ghost" Content="{DynamicResource TestAll}"
                      Command="{Binding TestAllCommand}"
                      IsEnabled="{Binding Session.IsCoreRunning}" />
              <Button Grid.Column="2" Classes="ghost" Content="{DynamicResource Refresh}"
                      Command="{Binding RefreshProxiesCommand}"
                      IsEnabled="{Binding Session.IsCoreRunning}" />
            </Grid>
            <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="14">
              <TextBox Text="{Binding SearchText}" PlaceholderText="{DynamicResource SearchNodes}"
                       MinHeight="34" />
              <CheckBox Grid.Column="1" Content="{DynamicResource SortByLatency}"
                        IsChecked="{Binding SortByLatency}" VerticalAlignment="Center" />
              <TextBlock Grid.Column="2" Text="{Binding NodeCountDisplay}"
                         Classes="faint" FontSize="13" VerticalAlignment="Center" />
            </Grid>
          </Grid>
          <Border Grid.Row="1" Background="{DynamicResource CardBorderBrush}" />
          <Grid Grid.Row="2">
            <ListBox Classes="node-list" ItemsSource="{Binding VisibleNodes}"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:ProxyNodeItemViewModel">
                  <Border Classes="node-row" Classes.selected="{Binding IsSelected}">
                    <Grid ColumnDefinitions="*,44">
                      <Button Classes="node-select" Command="{Binding SelectCommand}"
                              IsEnabled="{Binding CanApplySelection}">
                        <Grid ColumnDefinitions="18,*,96" ColumnSpacing="10">
                          <Grid Width="10" Height="10" VerticalAlignment="Center">
                            <Ellipse Fill="{DynamicResource CardBorderBrush}" />
                            <Ellipse Fill="{DynamicResource AccentBrush}"
                                     IsVisible="{Binding IsSelected}" />
                          </Grid>
                          <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="{Binding Name}" FontSize="15"
                                       FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding TypeDisplay}" Classes="muted" FontSize="13" />
                          </StackPanel>
                          <TextBlock Grid.Column="2" Text="{Binding DelayDisplay}"
                                     Classes="node-delay"
                                     Classes.fast="{Binding HasFastDelay}"
                                     Classes.medium="{Binding HasMediumDelay}"
                                     Classes.slow="{Binding HasSlowDelay}"
                                     HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </Grid>
                      </Button>
                      <Button Grid.Column="1" Classes="node-test" Content="↻"
                              Command="{Binding TestCommand}"
                              IsEnabled="{Binding !IsTesting}"
                              ToolTip.Tip="{DynamicResource Latency}" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
            <TextBlock Text="{DynamicResource NoMatchingNodes}" Classes="muted"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       IsVisible="{Binding !HasVisibleNodes}" />
          </Grid>
        </Grid>
      </Grid>
    </Border>
  </Grid>
</UserControl>
