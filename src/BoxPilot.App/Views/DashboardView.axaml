<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:BoxPilot.App.Controls"
             xmlns:vm="using:BoxPilot.App.ViewModels"
             x:Class="BoxPilot.App.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">
  <UserControl.Resources>
    <DataTemplate x:Key="ProxyNodeTemplate" x:DataType="vm:ProxyNodeItemViewModel">
      <Border Classes="node-row" Classes.selected="{Binding IsSelected}">
        <Grid ColumnDefinitions="*,64">
          <Button Classes="node-select" Command="{Binding SelectCommand}"
                  IsEnabled="{Binding CanApplySelection}">
            <Grid ColumnDefinitions="14,*,72" ColumnSpacing="10">
              <Grid Width="9" Height="9" VerticalAlignment="Center">
                <Ellipse Fill="{DynamicResource CardBorderBrush}" />
                <Ellipse Fill="{DynamicResource AccentBrush}"
                         IsVisible="{Binding IsSelected}" />
              </Grid>
              <StackPanel Grid.Column="1" Spacing="2">
                <TextBlock Text="{Binding Name}" FontSize="14"
                           FontWeight="SemiBold" TextWrapping="Wrap" />
                <TextBlock Text="{Binding TypeDisplay}" Classes="muted"
                           FontSize="12" />
              </StackPanel>
              <Border Grid.Column="2" Classes="delay-badge"
                      Classes.fast="{Binding HasFastDelay}"
                      Classes.medium="{Binding HasMediumDelay}"
                      Classes.slow="{Binding HasSlowDelay}"
                      VerticalAlignment="Center">
                <TextBlock Text="{Binding DelayDisplay}" Classes="node-delay"
                           Classes.fast="{Binding HasFastDelay}"
                           Classes.medium="{Binding HasMediumDelay}"
                           Classes.slow="{Binding HasSlowDelay}"
                           HorizontalAlignment="Center" />
              </Border>
            </Grid>
          </Button>
          <Button Grid.Column="1" Classes="node-test"
                  Content="{DynamicResource TestNode}"
                  Command="{Binding TestCommand}"
                  IsEnabled="{Binding !IsTesting}"
                  ToolTip.Tip="{DynamicResource Latency}" />
        </Grid>
      </Border>
    </DataTemplate>
  </UserControl.Resources>
  <Grid RowDefinitions="Auto,18,136,14,*">
    <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="16">
      <TextBlock Text="{DynamicResource NavDashboard}" Classes="page-title"
                 VerticalAlignment="Center" />

      <Border Grid.Column="1" Classes="mode-switch" VerticalAlignment="Center">
        <Grid ColumnDefinitions="72,72,72" ColumnSpacing="2">
          <Button Classes="segment" Classes.active="{Binding IsRuleMode}"
                  Content="{DynamicResource RuleMode}"
                  IsEnabled="{Binding Session.CanChangeRoutingMode}"
                  Command="{Binding SetRoutingModeCommand}" CommandParameter="Rule" />
          <Button Grid.Column="1" Classes="segment" Classes.active="{Binding IsGlobalMode}"
                  Content="{DynamicResource GlobalMode}"
                  IsEnabled="{Binding Session.CanChangeRoutingMode}"
                  Command="{Binding SetRoutingModeCommand}" CommandParameter="Global" />
          <Button Grid.Column="2" Classes="segment" Classes.active="{Binding IsDirectMode}"
                  Content="{DynamicResource DirectMode}"
                  IsEnabled="{Binding Session.CanChangeRoutingMode}"
                  Command="{Binding SetRoutingModeCommand}" CommandParameter="Direct" />
        </Grid>
      </Border>

      <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                  VerticalAlignment="Center">
        <Button Classes="ghost" Content="{DynamicResource Restart}"
                Command="{Binding RestartCommand}" IsEnabled="{Binding Session.CanStopCore}"
                IsVisible="{Binding Session.IsCoreRunning}" />
        <Button Classes="danger" Content="{DynamicResource Stop}"
                Command="{Binding StopCommand}"
                IsEnabled="{Binding Session.CanStopCore}"
                IsVisible="{Binding Session.IsCoreRunning}" />
        <Button Classes="primary" Content="{DynamicResource Start}"
                Command="{Binding StartCommand}" IsEnabled="{Binding Session.CanStartCore}"
                IsVisible="{Binding !Session.IsCoreRunning}" />
      </StackPanel>
    </Grid>

    <Border Grid.Row="2" Classes="overview-panel">
      <Grid ColumnDefinitions="1.8*,0.85*,1.05*,1.05*,1.35*,1.9*" ColumnSpacing="18">
        <StackPanel VerticalAlignment="Center" Spacing="4">
          <TextBlock Text="{DynamicResource ActiveProfile}" Classes="field-label" />
          <TextBlock Text="{Binding Session.SelectedProfile.Name, FallbackValue=—}"
                     FontSize="21" FontWeight="SemiBold"
                     TextTrimming="CharacterEllipsis" />
          <TextBlock Text="{Binding Session.SelectedProfile.UpdatedAtLocal,
                           StringFormat='{}{0:yyyy-MM-dd · HH:mm}'}"
                     Classes="muted numeric" FontSize="12" />
        </StackPanel>

        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="5">
          <TextBlock Text="{DynamicResource ProxyNodes}" Classes="field-label" />
          <TextBlock Text="{Binding Session.ActiveNodeDisplay}"
                     Classes="numeric" FontSize="17" FontWeight="SemiBold" />
        </StackPanel>

        <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="3">
          <TextBlock Text="{DynamicResource Download}" Classes="field-label" />
          <TextBlock Text="{Binding Session.DownloadRate}"
                     Classes="numeric" FontSize="16" FontWeight="SemiBold" />
          <StackPanel Orientation="Horizontal" Spacing="4">
            <TextBlock Text="{DynamicResource TotalTraffic}" Classes="faint"
                       FontSize="11" />
            <TextBlock Text="{Binding Session.DownloadTotal}" Classes="muted numeric"
                       FontSize="11" />
          </StackPanel>
        </StackPanel>

        <StackPanel Grid.Column="3" VerticalAlignment="Center" Spacing="3">
          <TextBlock Text="{DynamicResource Upload}" Classes="field-label" />
          <TextBlock Text="{Binding Session.UploadRate}"
                     Classes="numeric" FontSize="16" FontWeight="SemiBold" />
          <StackPanel Orientation="Horizontal" Spacing="4">
            <TextBlock Text="{DynamicResource TotalTraffic}" Classes="faint"
                       FontSize="11" />
            <TextBlock Text="{Binding Session.UploadTotal}" Classes="muted numeric"
                       FontSize="11" />
          </StackPanel>
        </StackPanel>

        <Border Grid.Column="4" Classes="status-tile"
                Classes.running="{Binding Session.IsCoreRunning}">
          <Grid RowDefinitions="Auto,*">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Grid Width="8" Height="8" VerticalAlignment="Center">
                <Ellipse Fill="{DynamicResource FaintTextBrush}" Opacity="0.45" />
                <Ellipse Fill="{DynamicResource SuccessBrush}"
                         IsVisible="{Binding Session.IsCoreRunning}" />
              </Grid>
              <TextBlock Text="{Binding Session.CoreStateDisplay}"
                         FontSize="17" FontWeight="SemiBold" />
            </StackPanel>
            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="9"
                        VerticalAlignment="Bottom">
              <TextBlock Text="{Binding Session.CoreVersion, StringFormat='v{0}'}"
                         Classes="muted numeric" FontSize="12" />
              <TextBlock Text="{Binding Session.Settings.MixedPort, StringFormat=':{0}'}"
                         Classes="muted numeric" FontSize="12" />
              <TextBlock Text="{Binding Session.TunDisplay, StringFormat='TUN {0}'}"
                         Classes="muted" FontSize="12" />
            </StackPanel>
          </Grid>
        </Border>

        <Grid Grid.Column="5" RowDefinitions="Auto,*">
          <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
            <TextBlock Text="{DynamicResource RealtimeTraffic}" Classes="field-label" />
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="9">
              <StackPanel Orientation="Horizontal" Spacing="4">
                <Ellipse Width="6" Height="6" Fill="{DynamicResource SuccessBrush}"
                         VerticalAlignment="Center" />
                <TextBlock Text="{DynamicResource DownloadShort}" Classes="faint"
                           FontSize="11" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="4">
                <Ellipse Width="6" Height="6" Fill="{DynamicResource AccentBrush}"
                         VerticalAlignment="Center" />
                <TextBlock Text="{DynamicResource UploadShort}" Classes="faint"
                           FontSize="11" />
              </StackPanel>
            </StackPanel>
          </Grid>
          <controls:TrafficChart Grid.Row="1" Margin="0,8,0,0"
                                 Samples="{Binding Session.TrafficHistory}"
                                 DownloadStroke="{DynamicResource SuccessBrush}"
                                 UploadStroke="{DynamicResource AccentBrush}"
                                 GridStroke="{DynamicResource CardBorderBrush}"
                                 AxisForeground="{DynamicResource FaintTextBrush}" />
        </Grid>
      </Grid>
    </Border>

    <Border Grid.Row="4" Classes="workspace"
            IsVisible="{Binding ShowProxySelection}">
      <Grid ColumnDefinitions="270,*">
        <Border Background="{DynamicResource SurfaceSubtleBrush}">
          <Grid RowDefinitions="54,*">
            <Grid Margin="18,0" ColumnDefinitions="*,Auto" VerticalAlignment="Center">
              <TextBlock Text="{DynamicResource PolicyGroups}" Classes="section-title" />
              <TextBlock Grid.Column="1" Text="{Binding GroupCountDisplay}"
                         Classes="faint numeric" FontSize="12" />
            </Grid>
            <Grid Grid.Row="1">
              <ListBox Classes="proxy-groups" ItemsSource="{Binding ProxyGroups}"
                       SelectedItem="{Binding SelectedGroup}"
                       Background="Transparent" BorderThickness="0"
                       ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:ProxyGroupItemViewModel">
                    <Grid Margin="11,7" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                      <StackPanel Spacing="3">
                        <TextBlock Text="{Binding DisplayName}" FontSize="14"
                                   FontWeight="SemiBold" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding SelectionDisplay}" Classes="muted"
                                   FontSize="12" TextWrapping="Wrap" />
                      </StackPanel>
                      <TextBlock Grid.Column="1" Text="{Binding CountDisplay}"
                                 Classes="faint numeric" FontSize="12"
                                 VerticalAlignment="Center" />
                    </Grid>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
              <TextBlock Text="{DynamicResource NoProxyGroups}" Classes="muted"
                         Margin="18" TextWrapping="Wrap" TextAlignment="Center"
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         IsVisible="{Binding !HasProxyGroups}" />
            </Grid>
          </Grid>
        </Border>

        <Grid Grid.Column="1" RowDefinitions="Auto,*">
          <Grid Margin="16,10" MinHeight="44"
                ColumnDefinitions="*,220,Auto,Auto"
                ColumnSpacing="10">
            <StackPanel VerticalAlignment="Center" Spacing="2">
              <TextBlock Text="{Binding SelectedGroup.DisplayName, FallbackValue=—}"
                         FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" />
              <TextBlock Text="{Binding SelectedGroup.SelectionDisplay, FallbackValue=—}"
                         Classes="muted" FontSize="12" TextWrapping="Wrap" />
            </StackPanel>
            <TextBox Grid.Column="1" Text="{Binding SearchText}"
                     PlaceholderText="{DynamicResource SearchNodes}" />
            <TextBlock Grid.Column="2" Text="{Binding NodeCountDisplay}"
                       Classes="faint numeric" FontSize="12" VerticalAlignment="Center" />
            <Button Grid.Column="3" Classes="primary"
                    Content="{DynamicResource TestAll}"
                    Command="{Binding TestAllCommand}"
                    IsEnabled="{Binding Session.IsCoreRunning}" />
          </Grid>

          <Grid Grid.Row="1">
            <ListBox Classes="node-list" ItemsSource="{Binding VisibleNodeRows}"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
              <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                  <VirtualizingStackPanel />
                </ItemsPanelTemplate>
              </ListBox.ItemsPanel>
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:ProxyNodeRowViewModel">
                  <Grid ColumnDefinitions="*,*">
                    <ContentControl Content="{Binding First}"
                                    ContentTemplate="{StaticResource ProxyNodeTemplate}"
                                    HorizontalContentAlignment="Stretch" />
                    <ContentControl Grid.Column="1" Content="{Binding Second}"
                                    ContentTemplate="{StaticResource ProxyNodeTemplate}"
                                    HorizontalContentAlignment="Stretch" />
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
            <TextBlock Text="{DynamicResource NoMatchingNodes}" Classes="muted"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       IsVisible="{Binding !HasVisibleNodes}" />
          </Grid>
        </Grid>
      </Grid>
    </Border>
  </Grid>
</UserControl>
