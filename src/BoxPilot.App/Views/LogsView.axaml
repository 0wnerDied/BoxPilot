<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:BoxPilot.App.Controls"
             xmlns:models="using:BoxPilot.Core.Models"
             xmlns:vm="using:BoxPilot.App.ViewModels"
             x:Class="BoxPilot.App.Views.LogsView"
             x:DataType="vm:LogsViewModel">
  <Grid RowDefinitions="Auto,24,*">
    <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
      <StackPanel>
        <TextBlock Text="{DynamicResource LogsTitle}" Classes="page-title" />
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12"
                  VerticalAlignment="Bottom" Margin="0,0,0,2">
        <CheckBox Content="{DynamicResource AutoScroll}" IsChecked="{Binding AutoScroll}" />
        <Button Classes="ghost" Content="{DynamicResource Clear}" Command="{Binding ClearCommand}" />
      </StackPanel>
    </Grid>

    <Border Grid.Row="2" Classes="dark-panel" Padding="0">
      <Grid RowDefinitions="40,1,*">
        <Grid Margin="16,0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10"
              VerticalAlignment="Center">
          <Ellipse Width="6" Height="6" Fill="{DynamicResource SuccessBrush}" />
          <TextBlock Grid.Column="1" Text="{DynamicResource LiveOutput}" Classes="dark-muted"
                     FontSize="12" LetterSpacing="0.8" />
          <TextBlock Grid.Column="2" Text="{Binding Session.Logs.Count}"
                     Classes="dark-muted" FontSize="12" />
        </Grid>
        <Border Grid.Row="1" Background="#28FFFFFF" />
        <ListBox Grid.Row="2" x:Name="LogList" Classes="log-list"
                 ItemsSource="{Binding Session.Logs}"
                 Background="Transparent" BorderThickness="0"
                 FontFamily="SFMono-Regular, Cascadia Code, Noto Sans Mono CJK SC, Consolas, monospace"
                 FontSize="13">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="models:CoreLogEntry">
              <Border Classes="log-row"
                      Classes.warning="{Binding IsWarning}"
                      Classes.error="{Binding IsError}"
                      Classes.fatal="{Binding IsFatal}">
                <Grid ColumnDefinitions="72,58,*" ColumnSpacing="10" Margin="12,5">
                  <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}"
                             Foreground="#8E857A" />
                  <TextBlock Grid.Column="1" Text="{Binding LevelLabel}" Classes="log-level"
                             Classes.system="{Binding IsSystem}"
                             Classes.trace="{Binding IsTrace}"
                             Classes.debug="{Binding IsDebug}"
                             Classes.info="{Binding IsInformation}"
                             Classes.warning="{Binding IsWarning}"
                             Classes.error="{Binding IsError}"
                             Classes.fatal="{Binding IsFatal}" />
                  <controls:AnsiTextBlock Grid.Column="2" Document="{Binding Content}"
                                          Foreground="{DynamicResource CodeForegroundBrush}"
                                          TextWrapping="Wrap" />
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>
    </Border>
  </Grid>
</UserControl>
