<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BoxPilot.App.ViewModels"
             x:Class="BoxPilot.App.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">
  <ScrollViewer HorizontalScrollBarVisibility="Disabled">
    <Grid RowDefinitions="Auto,18,Auto" Margin="0,0,0,4">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Text="{DynamicResource SettingsTitle}" Classes="page-title"
                   VerticalAlignment="Center" />
        <Button Grid.Column="1" Classes="primary" Content="{DynamicResource SaveSettings}"
                Command="{Binding SaveCommand}" IsEnabled="{Binding !Session.IsBusy}" />
      </Grid>

      <Grid Grid.Row="2" ColumnDefinitions="0.82*,1.18*" ColumnSpacing="14">
        <StackPanel Spacing="14">
          <Border Classes="panel">
            <StackPanel Spacing="14">
              <TextBlock Text="{DynamicResource Appearance}" Classes="section-title" />
              <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <StackPanel Spacing="5">
                  <TextBlock Text="{DynamicResource Theme}" Classes="field-label" />
                  <ComboBox ItemsSource="{Binding Themes}" SelectedItem="{Binding Theme}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate><TextBlock Text="{Binding DisplayName}" /></DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="5">
                  <TextBlock Text="{DynamicResource Language}" Classes="field-label" />
                  <ComboBox ItemsSource="{Binding Languages}" SelectedItem="{Binding Language}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate><TextBlock Text="{Binding DisplayName}" /></DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                </StackPanel>
              </Grid>
            </StackPanel>
          </Border>

          <Border Classes="panel">
            <StackPanel Spacing="16">
              <TextBlock Text="{DynamicResource LaunchSettings}" Classes="section-title" />
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                <TextBlock Text="{DynamicResource StartOnLaunch}"
                           VerticalAlignment="Center" TextWrapping="Wrap" />
                <ToggleSwitch Grid.Column="1" IsChecked="{Binding StartCoreOnLaunch}" />
              </Grid>
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                <TextBlock Text="{DynamicResource CloseToTray}"
                           VerticalAlignment="Center" TextWrapping="Wrap" />
                <ToggleSwitch Grid.Column="1" IsChecked="{Binding CloseToTray}" />
              </Grid>
              <Button Classes="ghost" Content="{DynamicResource DataDirectory}"
                      Command="{Binding OpenDataDirectoryCommand}"
                      HorizontalAlignment="Left" />
            </StackPanel>
          </Border>
        </StackPanel>

        <Border Grid.Column="1" Classes="panel">
          <StackPanel Spacing="15">
            <TextBlock Text="{DynamicResource CoreSettings}" Classes="section-title" />

            <StackPanel Spacing="5">
              <TextBlock Text="{DynamicResource CorePath}" Classes="field-label" />
              <TextBox Text="{Binding CorePath}" PlaceholderText="sing-box" />
            </StackPanel>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
              <StackPanel Spacing="5">
                <TextBlock Text="{DynamicResource MixedPort}" Classes="field-label" />
                <NumericUpDown Classes="port-input" Value="{Binding MixedPort}"
                               Minimum="1" Maximum="65535" />
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="5">
                <TextBlock Text="{DynamicResource ApiPort}" Classes="field-label" />
                <NumericUpDown Classes="port-input" Value="{Binding ApiPort}"
                               Minimum="1" Maximum="65535" />
              </StackPanel>
            </Grid>

            <TextBlock Text="{DynamicResource Network}" Classes="section-title"
                       Margin="0,5,0,0" />

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
              <TextBlock Text="{DynamicResource SystemProxy}"
                         VerticalAlignment="Center" TextWrapping="Wrap" />
              <ToggleSwitch Grid.Column="1" IsChecked="{Binding EnableSystemProxy}" />
            </Grid>

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
              <StackPanel Spacing="3">
                <TextBlock Text="{DynamicResource AllowLan}" TextWrapping="Wrap" />
                <TextBlock Text="{DynamicResource AllowLanHint}" Classes="muted"
                           FontSize="13" TextWrapping="Wrap" />
              </StackPanel>
              <ToggleSwitch Grid.Column="1" IsChecked="{Binding AllowLan}"
                            VerticalAlignment="Top" />
            </Grid>

            <StackPanel Spacing="5">
              <TextBlock Text="{DynamicResource CustomDns}" Classes="field-label" />
              <TextBox Text="{Binding CustomDnsServer}"
                       PlaceholderText="{DynamicResource CustomDnsHint}" />
            </StackPanel>

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
              <StackPanel Spacing="4">
                <TextBlock Text="{DynamicResource TunMode}" />
                <TextBlock Text="{DynamicResource NetworkChangesHint}" Classes="muted"
                           FontSize="13" TextWrapping="Wrap" />
                <Button Classes="ghost compact" Content="{DynamicResource RemoveTunService}"
                        Command="{Binding UninstallTunServiceCommand}"
                        IsVisible="{Binding Session.IsTunServiceInstalled}"
                        HorizontalAlignment="Left" Margin="0,5,0,0" />
              </StackPanel>
              <ToggleSwitch Grid.Column="1" IsChecked="{Binding EnableTun}"
                            VerticalAlignment="Top" />
            </Grid>
          </StackPanel>
        </Border>
      </Grid>
    </Grid>
  </ScrollViewer>
</UserControl>
