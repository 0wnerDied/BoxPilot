<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BoxPilot.App.ViewModels"
             x:Class="BoxPilot.App.Views.ConfigurationView"
             x:DataType="vm:ConfigurationViewModel">
  <Grid RowDefinitions="Auto,24,Auto,10,*">
    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="24">
      <StackPanel>
        <TextBlock Text="{DynamicResource ConfigurationTitle}" Classes="page-title" />
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="9"
                  VerticalAlignment="Bottom" Margin="0,0,0,2">
        <Button Classes="ghost" Content="{DynamicResource Format}"
                Command="{Binding FormatCommand}" IsEnabled="{Binding !Session.IsBusy}" />
        <Button Classes="ghost" Content="{DynamicResource Validate}"
                Command="{Binding ValidateCommand}" IsEnabled="{Binding !Session.IsBusy}" />
        <Button Classes="primary" Content="{DynamicResource Save}"
                Command="{Binding SaveCommand}" IsEnabled="{Binding !Session.IsBusy}" />
      </StackPanel>
    </Grid>

    <Border Grid.Row="2" Classes="soft-panel" Padding="12,9">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Text="{Binding Session.SelectedProfile.Name, FallbackValue=—}"
                     FontWeight="SemiBold" />
          <TextBlock Text="{DynamicResource ConfigurationValidationLabel}"
                     Classes="faint" FontSize="13" VerticalAlignment="Center" />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                    IsVisible="{Binding Session.IsConfigurationDirty}">
          <Ellipse Width="6" Height="6" Fill="{DynamicResource AccentBrush}"
                   VerticalAlignment="Center" />
          <TextBlock Text="{DynamicResource UnsavedChanges}" Classes="muted" FontSize="13" />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                    IsVisible="{Binding !Session.IsConfigurationDirty}">
          <Ellipse Width="6" Height="6" Fill="{DynamicResource SuccessBrush}"
                   VerticalAlignment="Center" />
          <TextBlock Text="{DynamicResource ChangesSaved}" Classes="muted" FontSize="13" />
        </StackPanel>
      </Grid>
    </Border>

    <TextBox Grid.Row="4" Classes="editor" Text="{Binding Session.ConfigurationText}"
             AcceptsReturn="True" AcceptsTab="True" TextWrapping="NoWrap"
             PlaceholderText="{DynamicResource JsonPlaceholder}"
             HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"
             ScrollViewer.HorizontalScrollBarVisibility="Auto"
             ScrollViewer.VerticalScrollBarVisibility="Auto" />
  </Grid>
</UserControl>
