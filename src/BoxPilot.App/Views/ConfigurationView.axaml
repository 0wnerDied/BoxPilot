<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:BoxPilot.App.Controls"
             xmlns:models="using:BoxPilot.Core.Models"
             xmlns:vm="using:BoxPilot.App.ViewModels"
             x:Class="BoxPilot.App.Views.ConfigurationView"
             x:DataType="vm:ConfigurationViewModel">
  <Grid RowDefinitions="Auto,18,Auto,14,*">
    <TextBlock Text="{DynamicResource ConfigurationTitle}" Classes="page-title" />

    <Border Grid.Row="2" Classes="panel" Padding="16">
      <Grid RowDefinitions="Auto,12,Auto,Auto">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
          <StackPanel Spacing="3">
            <TextBlock Text="{DynamicResource CustomRouting}" Classes="section-title" />
            <TextBlock Text="{DynamicResource CustomRoutingHint}" Classes="muted"
                       FontSize="13" />
          </StackPanel>
          <TextBlock Grid.Column="1" Text="{Binding Session.CustomRuleSets.Count}"
                     Classes="faint numeric" VerticalAlignment="Center" />
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="210,Auto,*,Auto" ColumnSpacing="9">
          <ComboBox ItemsSource="{Binding Session.RoutingOutbounds}"
                    SelectedItem="{Binding SelectedRoutingOutbound}"
                    PlaceholderText="{DynamicResource RouteTarget}"
                    IsEnabled="{Binding Session.CanManageRuleSets}">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="models:RoutingOutbound">
                <TextBlock Text="{Binding Tag}" TextTrimming="CharacterEllipsis" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <Button Grid.Column="1" Classes="ghost"
                  Content="{DynamicResource ImportLocalRuleSet}"
                  Click="ImportRuleSetClicked"
                  IsEnabled="{Binding Session.CanManageRuleSets}" />
          <TextBox Grid.Column="2" Text="{Binding RemoteRuleSetUrl}"
                   PlaceholderText="{DynamicResource RemoteRuleSetUrl}"
                   IsEnabled="{Binding Session.CanManageRuleSets}" />
          <Button Grid.Column="3" Classes="primary"
                  Content="{DynamicResource AddRemoteRuleSet}"
                  Command="{Binding AddRemoteRuleSetCommand}"
                  IsEnabled="{Binding Session.CanManageRuleSets}" />
        </Grid>

        <ScrollViewer Grid.Row="3" MaxHeight="104" Margin="0,8,0,0"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{Binding Session.CustomRuleSets}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="models:CustomRuleSet">
                <Border Background="{DynamicResource SurfaceSubtleBrush}"
                        CornerRadius="8" Margin="0,3" Padding="12,8">
                  <Grid ColumnDefinitions="*,180,Auto" ColumnSpacing="12">
                    <StackPanel Spacing="2">
                      <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                 TextTrimming="CharacterEllipsis" />
                      <TextBlock Text="{Binding Format}" Classes="muted" FontSize="12" />
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding Outbound}" Classes="muted"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                    <Button Grid.Column="2" Classes="danger compact"
                            Content="{DynamicResource Delete}"
                            Click="RemoveRuleSetClicked" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Grid>
    </Border>

    <Border Grid.Row="4" Classes="workspace">
      <Grid RowDefinitions="52,*">
        <Grid Margin="16,0" ColumnDefinitions="*,Auto,Auto,Auto,Auto"
              ColumnSpacing="8" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="{Binding Session.SelectedProfile.Name, FallbackValue=—}"
                       FontWeight="SemiBold" VerticalAlignment="Center" />
            <TextBlock Text="{DynamicResource ConfigurationValidationLabel}"
                       Classes="faint" FontSize="12" VerticalAlignment="Center" />
          </StackPanel>

          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                      IsVisible="{Binding Session.IsConfigurationDirty}">
            <Ellipse Width="6" Height="6" Fill="{DynamicResource AccentBrush}"
                     VerticalAlignment="Center" />
            <TextBlock Text="{DynamicResource UnsavedChanges}" Classes="muted"
                       FontSize="12" VerticalAlignment="Center" />
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                      IsVisible="{Binding !Session.IsConfigurationDirty}">
            <Ellipse Width="6" Height="6" Fill="{DynamicResource SuccessBrush}"
                     VerticalAlignment="Center" />
            <TextBlock Text="{DynamicResource ChangesSaved}" Classes="muted"
                       FontSize="12" VerticalAlignment="Center" />
          </StackPanel>

          <Button Grid.Column="2" Classes="ghost compact" Content="{DynamicResource Format}"
                  Command="{Binding FormatCommand}" IsEnabled="{Binding !Session.IsBusy}" />
          <Button Grid.Column="3" Classes="ghost compact" Content="{DynamicResource Validate}"
                  Command="{Binding ValidateCommand}" IsEnabled="{Binding !Session.IsBusy}" />
          <Button Grid.Column="4" Classes="primary compact" Content="{DynamicResource Save}"
                  Command="{Binding SaveCommand}" IsEnabled="{Binding !Session.IsBusy}" />
        </Grid>

        <controls:CodeEditor Grid.Row="1" Classes="embedded-editor" Language="Json"
                             Value="{Binding Session.ConfigurationText, Mode=TwoWay}"
                             ShowLineNumbers="True" WordWrap="False"
                             Placeholder="{DynamicResource JsonPlaceholder}"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto" />
      </Grid>
    </Border>
  </Grid>
</UserControl>
