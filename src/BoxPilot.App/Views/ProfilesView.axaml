<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BoxPilot.App.ViewModels"
             x:Class="BoxPilot.App.Views.ProfilesView"
             x:DataType="vm:ProfilesViewModel">
  <Grid RowDefinitions="Auto,24,*">
    <TextBlock Grid.Row="0" Text="{DynamicResource ProfilesTitle}" Classes="page-title" />

    <Border Grid.Row="2" Classes="panel" Padding="0">
      <Grid RowDefinitions="Auto,1,*">
        <Grid Grid.Row="0" Margin="22" RowDefinitions="Auto,14,Auto">
          <TextBlock Grid.Row="0" Text="{DynamicResource ImportSection}"
                     Classes="section-title" />

          <Grid Grid.Row="2" ColumnDefinitions="220,*,Auto,Auto,Auto" ColumnSpacing="12">
            <StackPanel Spacing="6">
              <TextBlock Text="{DynamicResource SubscriptionName}" Classes="muted"
                         FontSize="13" />
              <TextBox Text="{Binding ProfileName}"
                       PlaceholderText="{DynamicResource SubscriptionNamePlaceholder}" />
            </StackPanel>

            <StackPanel Grid.Column="1" Spacing="6">
              <TextBlock Text="{DynamicResource SubscriptionUrl}" Classes="muted"
                         FontSize="13" />
              <TextBox Text="{Binding SubscriptionUrl}" PlaceholderText="https://…"
                       HorizontalAlignment="Stretch" />
            </StackPanel>

            <Button Grid.Column="2" Classes="primary" Content="{DynamicResource Import}"
                    Command="{Binding ImportCommand}"
                    IsEnabled="{Binding Session.CanModifyProfiles}"
                    MinWidth="126" VerticalAlignment="Bottom" />
            <Button Grid.Column="3" Classes="ghost" Content="{DynamicResource CreateBlank}"
                    Command="{Binding CreateBlankCommand}"
                    IsEnabled="{Binding Session.CanModifyProfiles}"
                    MinWidth="126" VerticalAlignment="Bottom" />
            <Button Grid.Column="4" Classes="ghost"
                    Content="{DynamicResource ImportConfiguration}"
                    Click="ImportConfigurationClicked"
                    IsEnabled="{Binding Session.CanModifyProfiles}"
                    MinWidth="126" VerticalAlignment="Bottom" />
          </Grid>
        </Grid>

        <Border Grid.Row="1" Background="{DynamicResource CardBorderBrush}" />

        <Grid Grid.Row="2" Margin="22" RowDefinitions="Auto,14,*,Auto">
          <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="16">
            <TextBlock Text="{DynamicResource ProfileLibrary}" Classes="section-title" />
            <TextBlock Grid.Column="1" Text="{Binding Session.Profiles.Count}"
                       Classes="faint" FontSize="18" VerticalAlignment="Center" />
          </Grid>

          <ListBox Grid.Row="2" Classes="profile-grid"
                   ItemsSource="{Binding Session.Profiles}"
                   SelectedItem="{Binding Session.SelectedProfile}"
                   Background="Transparent" BorderThickness="0"
                   IsEnabled="{Binding Session.CanModifyProfiles}">
            <ListBox.ItemsPanel>
              <ItemsPanelTemplate>
                <UniformGrid Columns="2" ColumnSpacing="12" RowSpacing="10"
                             VerticalAlignment="Top" />
              </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Grid ColumnDefinitions="34,*,Auto" Margin="11,9" ColumnSpacing="12">
                  <Border Width="30" Height="30" CornerRadius="4"
                          Background="{DynamicResource SurfaceSubtleBrush}">
                    <TextBlock Text="{Binding NodeCount}" FontSize="12" FontWeight="SemiBold"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                  <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <StackPanel Orientation="Horizontal" Spacing="4">
                      <TextBlock Text="{Binding NodeCount}" Classes="muted" FontSize="12" />
                      <TextBlock Text="{DynamicResource Nodes}" Classes="muted" FontSize="12" />
                    </StackPanel>
                  </StackPanel>
                  <TextBlock Grid.Column="2"
                             Text="{Binding UpdatedAtLocal, StringFormat='{}{0:yyyy-MM-dd  HH:mm}'}"
                             Classes="faint" FontSize="12" VerticalAlignment="Center" />
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="0,14,0,0">
            <Border Classes="soft-panel" Padding="12,9"
                    IsVisible="{Binding IsDeleteConfirmationVisible}">
              <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                <StackPanel Spacing="2" VerticalAlignment="Center">
                  <TextBlock Text="{DynamicResource DeleteProfileQuestion}"
                             FontWeight="SemiBold" FontSize="14" />
                  <TextBlock Text="{DynamicResource DeleteProfileHint}"
                             Classes="muted" FontSize="13" TextWrapping="Wrap" />
                </StackPanel>
                <Button Grid.Column="1" Classes="ghost" Content="{DynamicResource Cancel}"
                        Command="{Binding CancelDeleteCommand}" />
                <Button Grid.Column="2" Classes="danger" Content="{DynamicResource ConfirmDelete}"
                        Command="{Binding ConfirmDeleteCommand}" />
              </Grid>
            </Border>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="9"
                        IsVisible="{Binding !IsDeleteConfirmationVisible}">
              <Button Classes="ghost" Content="{DynamicResource ExportConfiguration}"
                      Click="ExportConfigurationClicked"
                      IsEnabled="{Binding Session.CanExportConfiguration}" />
              <Button Classes="ghost" Content="{DynamicResource Update}"
                      Command="{Binding RefreshCommand}"
                      IsEnabled="{Binding Session.CanRefreshSubscription}" />
              <Button Classes="danger" Content="{DynamicResource Delete}"
                      Command="{Binding BeginDeleteCommand}"
                      IsEnabled="{Binding Session.CanDeleteProfile}" />
            </StackPanel>
          </Grid>
        </Grid>
      </Grid>
    </Border>
  </Grid>
</UserControl>
