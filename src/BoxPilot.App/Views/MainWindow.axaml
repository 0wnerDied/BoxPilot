<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:BoxPilot.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1320"
        d:DesignHeight="820"
        x:Class="BoxPilot.App.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Width="1320"
        Height="820"
        MinWidth="1080"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/boxpilot.png"
        Title="BoxPilot">
  <Grid RowDefinitions="64,*,34">
    <Border Grid.Row="0" BorderBrush="{DynamicResource CardBorderBrush}"
            BorderThickness="0,0,0,1">
      <Grid Margin="36,0" ColumnDefinitions="Auto,42,*" VerticalAlignment="Stretch">
        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <Border Width="30" Height="30" CornerRadius="4"
                  Background="{DynamicResource PrimaryActionBrush}">
            <TextBlock Text="B" Foreground="{DynamicResource ActionForegroundBrush}"
                       FontSize="16" FontWeight="SemiBold"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <TextBlock Text="{DynamicResource AppName}" Classes="brand"
                     FontSize="17" FontWeight="SemiBold"
                     VerticalAlignment="Center" />
        </StackPanel>

        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="3"
                    VerticalAlignment="Stretch">
          <Button Classes="topnav" Classes.active="{Binding IsDashboardSelected}"
                  Content="{DynamicResource NavDashboard}"
                  Command="{Binding NavigateCommand}" CommandParameter="dashboard" />
          <Button Classes="topnav" Classes.active="{Binding IsProfilesSelected}"
                  Content="{DynamicResource NavProfiles}"
                  Command="{Binding NavigateCommand}" CommandParameter="profiles" />
          <Button Classes="topnav" Classes.active="{Binding IsConfigurationSelected}"
                  Content="{DynamicResource NavConfiguration}"
                  Command="{Binding NavigateCommand}" CommandParameter="configuration" />
          <Button Classes="topnav" Classes.active="{Binding IsLogsSelected}"
                  Content="{DynamicResource NavLogs}"
                  Command="{Binding NavigateCommand}" CommandParameter="logs" />
          <Button Classes="topnav" Classes.active="{Binding IsToolsSelected}"
                  Content="{DynamicResource NavTools}"
                  Command="{Binding NavigateCommand}" CommandParameter="tools" />
          <Button Classes="topnav" Classes.active="{Binding IsSettingsSelected}"
                  Content="{DynamicResource NavSettings}"
                  Command="{Binding NavigateCommand}" CommandParameter="settings" />
        </StackPanel>
      </Grid>
    </Border>

    <TransitioningContentControl Grid.Row="1" Content="{Binding CurrentPage}"
                                 Margin="42,24,42,18">
      <TransitioningContentControl.PageTransition>
        <CrossFade Duration="0:0:0.16" />
      </TransitioningContentControl.PageTransition>
    </TransitioningContentControl>

    <Border Grid.Row="2" BorderBrush="{DynamicResource CardBorderBrush}"
            BorderThickness="0,1,0,0" Padding="46,0">
      <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
        <TextBlock Text="{DynamicResource Working}" Classes="muted" FontSize="12"
                   IsVisible="{Binding Session.IsBusy}" />
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
          <TextBlock Text="{Binding Session.CoreVersion, StringFormat='sing-box {0}'}"
                     Classes="faint" FontSize="12" VerticalAlignment="Center" />
          <ProgressBar Width="78" Height="2" IsIndeterminate="{Binding Session.IsBusy}"
                       IsVisible="{Binding Session.IsBusy}" />
        </StackPanel>
      </Grid>
    </Border>

    <ItemsControl x:Name="ToastRegion" Grid.RowSpan="3"
                  ItemsSource="{Binding Session.Toast.Items}"
                  HorizontalAlignment="Right" VerticalAlignment="Top"
                  Width="420" Margin="0,76,36,0" ZIndex="100"
                  IsHitTestVisible="False">
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <StackPanel Spacing="9" />
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <ItemsControl.ItemTemplate>
        <DataTemplate x:DataType="vm:ToastItemViewModel">
          <Border Classes="toast"
                  Classes.dismissing="{Binding IsDismissing}"
                  Classes.pointer-over="{Binding IsPointerOver}">
            <Grid ColumnDefinitions="3,12,*">
              <Border Classes="toast-indicator"
                      Classes.success="{Binding IsSuccess}"
                      Classes.error="{Binding IsError}"
                      CornerRadius="99" />
              <ScrollViewer Grid.Column="2" MaxHeight="110"
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto"
                            HorizontalContentAlignment="Stretch">
                <TextBlock Text="{Binding Message}" Classes="on-dark"
                           FontSize="14" TextWrapping="Wrap" />
              </ScrollViewer>
            </Grid>
          </Border>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>
  </Grid>
</Window>
