<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="BoxPilot.App.App"
             xmlns:edit="using:AvaloniaEdit"
             xmlns:local="using:BoxPilot.App"
             xmlns:vm="using:BoxPilot.App.ViewModels"
             x:DataType="vm:TrayViewModel"
             Name="BoxPilot"
             RequestedThemeVariant="Default">
  <NativeMenu.Menu>
    <NativeMenu>
      <NativeMenuItem Header="{DynamicResource AboutBoxPilot}"
                      Command="{Binding ShowAboutCommand}" />
      <NativeMenuItem Header="{DynamicResource MenuSettings}"
                      Gesture="Meta+OemComma"
                      Command="{Binding OpenSettingsCommand}" />
    </NativeMenu>
  </NativeMenu.Menu>

  <TrayIcon.Icons>
    <TrayIcons>
      <TrayIcon Icon="/Assets/boxpilot-tray.png"
                MacOSProperties.IsTemplateIcon="True"
                IsVisible="True"
                ToolTipText="BoxPilot"
                Command="{Binding ShowWindowCommand}">
        <TrayIcon.Menu>
          <NativeMenu>
            <NativeMenuItem Header="{DynamicResource OpenBoxPilot}"
                            Command="{Binding ShowWindowCommand}" />
            <NativeMenuItem Header="{DynamicResource MenuSettings}"
                            Command="{Binding OpenSettingsCommand}" />
            <NativeMenuItemSeparator />
            <NativeMenuItem Header="{DynamicResource Start}" Command="{Binding StartCommand}" />
            <NativeMenuItem Header="{DynamicResource Stop}" Command="{Binding StopCommand}" />
            <NativeMenuItemSeparator />
            <NativeMenuItem Header="{DynamicResource Quit}" Command="{Binding QuitCommand}" />
          </NativeMenu>
        </TrayIcon.Menu>
      </TrayIcon>
    </TrayIcons>
  </TrayIcon.Icons>

  <Application.DataTemplates>
    <local:ViewLocator />
  </Application.DataTemplates>

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
          <SolidColorBrush x:Key="AppBackgroundBrush">#F3F0E9</SolidColorBrush>
          <SolidColorBrush x:Key="SurfaceBrush">#FAF8F3</SolidColorBrush>
          <SolidColorBrush x:Key="SurfaceSubtleBrush">#ECE7DE</SolidColorBrush>
          <SolidColorBrush x:Key="InputBrush">#FDFBF7</SolidColorBrush>
          <SolidColorBrush x:Key="SidebarBrush">#ECE7DE</SolidColorBrush>
          <SolidColorBrush x:Key="SidebarHoverBrush">#E4DDD2</SolidColorBrush>
          <SolidColorBrush x:Key="CardBorderBrush">#D7D0C5</SolidColorBrush>
          <SolidColorBrush x:Key="PrimaryTextBrush">#231F1B</SolidColorBrush>
          <SolidColorBrush x:Key="MutedTextBrush">#6B645B</SolidColorBrush>
          <SolidColorBrush x:Key="FaintTextBrush">#81796F</SolidColorBrush>
          <SolidColorBrush x:Key="PrimaryActionBrush">#29241F</SolidColorBrush>
          <SolidColorBrush x:Key="PrimaryActionHoverBrush">#3B342D</SolidColorBrush>
          <SolidColorBrush x:Key="ActionForegroundBrush">#F8F4EC</SolidColorBrush>
          <SolidColorBrush x:Key="CodeBackgroundBrush">#211E1A</SolidColorBrush>
          <SolidColorBrush x:Key="CodeForegroundBrush">#EEE8DD</SolidColorBrush>
          <SolidColorBrush x:Key="DarkModuleBrush">#29251F</SolidColorBrush>
          <SolidColorBrush x:Key="DarkModuleBorderBrush">#3A342D</SolidColorBrush>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
          <SolidColorBrush x:Key="AppBackgroundBrush">#171512</SolidColorBrush>
          <SolidColorBrush x:Key="SurfaceBrush">#201D19</SolidColorBrush>
          <SolidColorBrush x:Key="SurfaceSubtleBrush">#29251F</SolidColorBrush>
          <SolidColorBrush x:Key="InputBrush">#25211D</SolidColorBrush>
          <SolidColorBrush x:Key="SidebarBrush">#1B1815</SolidColorBrush>
          <SolidColorBrush x:Key="SidebarHoverBrush">#2B2621</SolidColorBrush>
          <SolidColorBrush x:Key="CardBorderBrush">#3B352E</SolidColorBrush>
          <SolidColorBrush x:Key="PrimaryTextBrush">#EEE9DF</SolidColorBrush>
          <SolidColorBrush x:Key="MutedTextBrush">#BEB5AA</SolidColorBrush>
          <SolidColorBrush x:Key="FaintTextBrush">#948B81</SolidColorBrush>
          <SolidColorBrush x:Key="PrimaryActionBrush">#EAE3D8</SolidColorBrush>
          <SolidColorBrush x:Key="PrimaryActionHoverBrush">#FFF9EF</SolidColorBrush>
          <SolidColorBrush x:Key="ActionForegroundBrush">#231F1B</SolidColorBrush>
          <SolidColorBrush x:Key="CodeBackgroundBrush">#0F0E0C</SolidColorBrush>
          <SolidColorBrush x:Key="CodeForegroundBrush">#E8E1D6</SolidColorBrush>
          <SolidColorBrush x:Key="DarkModuleBrush">#0F0E0C</SolidColorBrush>
          <SolidColorBrush x:Key="DarkModuleBorderBrush">#312C26</SolidColorBrush>
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>

      <SolidColorBrush x:Key="AccentBrush">#9B6243</SolidColorBrush>
      <SolidColorBrush x:Key="AccentSoftBrush">#229B6243</SolidColorBrush>
      <SolidColorBrush x:Key="SuccessBrush">#6F8872</SolidColorBrush>
      <SolidColorBrush x:Key="SuccessSoftBrush">#246F8872</SolidColorBrush>
      <SolidColorBrush x:Key="DangerBrush">#A5574B</SolidColorBrush>
      <SolidColorBrush x:Key="DangerSoftBrush">#22A5574B</SolidColorBrush>
      <SolidColorBrush x:Key="DarkTextBrush">#F3EDE3</SolidColorBrush>
      <SolidColorBrush x:Key="DarkMutedBrush">#B8AEA1</SolidColorBrush>
    </ResourceDictionary>
  </Application.Resources>

  <Application.Styles>
    <FluentTheme>
      <FluentTheme.Palettes>
        <ColorPaletteResources x:Key="Light" Accent="#9B6243"
                               RegionColor="#FAF8F3" ErrorText="#A5574B" />
        <ColorPaletteResources x:Key="Dark" Accent="#B77956"
                               RegionColor="#201D19" ErrorText="#D27A6D" />
      </FluentTheme.Palettes>
    </FluentTheme>
    <StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml" />

    <Style Selector="Window">
      <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}" />
      <Setter Property="FontFamily"
              Value="SF Pro Text, Segoe UI, PingFang SC, Microsoft YaHei UI, Noto Sans CJK SC, sans-serif" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    </Style>
    <Style Selector="TextBlock.brand">
      <Setter Property="FontFamily"
              Value="Songti SC, STSong, Noto Serif CJK SC, Noto Serif CJK, serif" />
    </Style>
    <Style Selector="TextBlock.page-title">
      <Setter Property="FontFamily"
              Value="Songti SC, STSong, Noto Serif CJK SC, Noto Serif CJK, serif" />
      <Setter Property="FontSize" Value="26" />
      <Setter Property="FontWeight" Value="Medium" />
      <Setter Property="LetterSpacing" Value="0.2" />
      <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    </Style>
    <Style Selector="TextBlock.section-title">
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    </Style>
    <Style Selector="TextBlock.numeric">
      <Setter Property="FontFeatures" Value="tnum" />
    </Style>
    <Style Selector="TextBlock.field-label">
      <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
      <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="TextBlock.muted">
      <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
    </Style>
    <Style Selector="TextBlock.faint">
      <Setter Property="Foreground" Value="{DynamicResource FaintTextBrush}" />
    </Style>
    <Style Selector="TextBlock.on-dark">
      <Setter Property="Foreground" Value="{DynamicResource DarkTextBrush}" />
    </Style>
    <Style Selector="TextBlock.dark-muted">
      <Setter Property="Foreground" Value="{DynamicResource DarkMutedBrush}" />
    </Style>
    <Style Selector="Border.panel">
      <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="11" />
      <Setter Property="Padding" Value="20" />
    </Style>
    <Style Selector="Border.dark-panel">
      <Setter Property="Background" Value="{DynamicResource DarkModuleBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource DarkModuleBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="11" />
      <Setter Property="Padding" Value="20" />
      <Setter Property="ClipToBounds" Value="True" />
    </Style>
    <Style Selector="Border.soft-panel">
      <Setter Property="Background" Value="{DynamicResource SurfaceSubtleBrush}" />
      <Setter Property="CornerRadius" Value="9" />
      <Setter Property="Padding" Value="14" />
    </Style>
    <Style Selector="Border.workspace">
      <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="11" />
      <Setter Property="ClipToBounds" Value="True" />
    </Style>
    <Style Selector="Border.overview-panel">
      <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
      <Setter Property="CornerRadius" Value="11" />
      <Setter Property="Padding" Value="18" />
    </Style>
    <Style Selector="Border.status-tile">
      <Setter Property="Background" Value="{DynamicResource SurfaceSubtleBrush}" />
      <Setter Property="CornerRadius" Value="9" />
      <Setter Property="Padding" Value="14" />
    </Style>
    <Style Selector="Border.status-tile.running">
      <Setter Property="Background" Value="{DynamicResource SuccessSoftBrush}" />
    </Style>
    <Style Selector="Border.mode-switch">
      <Setter Property="Background" Value="{DynamicResource SurfaceSubtleBrush}" />
      <Setter Property="CornerRadius" Value="9" />
      <Setter Property="Padding" Value="3" />
    </Style>
    <Style Selector="Border.command-frame">
      <Setter Property="Background" Value="{DynamicResource CodeBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource DarkModuleBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="ClipToBounds" Value="True" />
    </Style>
    <Style Selector="Border.command-frame:focus-within">
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="Border.toast">
      <Setter Property="Background" Value="{DynamicResource DarkModuleBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource DarkModuleBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="14,12" />
      <Setter Property="Opacity" Value="1" />
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.45" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Border.toast.dismissing">
      <Setter Property="Opacity" Value="0" />
    </Style>
    <Style Selector="Border.toast.pointer-over">
      <Setter Property="Opacity" Value="0" />
    </Style>
    <Style Selector="Border.toast-indicator">
      <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="Border.toast-indicator.success">
      <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
    </Style>
    <Style Selector="Border.toast-indicator.error">
      <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
    </Style>
    <Style Selector="Button">
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="14,8" />
      <Setter Property="MinHeight" Value="40" />
      <Setter Property="FontWeight" Value="Medium" />
      <Setter Property="RenderTransform" Value="translate(0px, 0px)" />
      <Setter Property="Transitions">
        <Transitions>
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button:pointerover">
      <Setter Property="RenderTransform" Value="translate(0px, -1px)" />
    </Style>
    <Style Selector="Button:disabled">
      <Setter Property="Opacity" Value="0.45" />
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="{DynamicResource PrimaryActionBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource ActionForegroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PrimaryActionBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button.primary /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource PrimaryActionBrush}" />
      <Setter Property="TextBlock.Foreground" Value="{DynamicResource ActionForegroundBrush}" />
    </Style>
    <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource PrimaryActionHoverBrush}" />
    </Style>
    <Style Selector="Button.ghost">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource SurfaceSubtleBrush}" />
    </Style>
    <Style Selector="Button.danger">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
      <Setter Property="BorderBrush" Value="#55A5574B" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource DangerSoftBrush}" />
    </Style>
    <Style Selector="Button.compact">
      <Setter Property="MinHeight" Value="38" />
      <Setter Property="Padding" Value="11,7" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="Button.icon">
      <Setter Property="Width" Value="40" />
      <Setter Property="MinWidth" Value="40" />
      <Setter Property="Height" Value="40" />
      <Setter Property="MinHeight" Value="40" />
      <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="Button.segment">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="7" />
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Width" Value="72" />
      <Setter Property="MinWidth" Value="72" />
      <Setter Property="Padding" Value="0,6" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="RenderTransform" Value="translate(0px, 0px)" />
    </Style>
    <Style Selector="Button.segment:pointerover">
      <Setter Property="RenderTransform" Value="translate(0px, 0px)" />
    </Style>
    <Style Selector="Button.segment:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource SidebarHoverBrush}" />
    </Style>
    <Style Selector="Button.segment.active">
      <Setter Property="Background" Value="{DynamicResource InputBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
    </Style>
    <Style Selector="Button.segment.active /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource InputBrush}" />
    </Style>
    <Style Selector="Button.chip">
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Padding" Value="10,5" />
      <Setter Property="CornerRadius" Value="99" />
      <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="Button.topnav">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0,0,0,2" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="Padding" Value="11,2" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="RenderTransform" Value="translate(0px, 0px)" />
    </Style>
    <Style Selector="Button.topnav:pointerover">
      <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
      <Setter Property="RenderTransform" Value="translate(0px, -1px)" />
    </Style>
    <Style Selector="Button.topnav:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.topnav.active">
      <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="TextBox, ComboBox, NumericUpDown">
      <Setter Property="Background" Value="{DynamicResource InputBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="MinHeight" Value="40" />
    </Style>
    <Style Selector="TextBox">
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBox.command-input">
      <Setter Property="Background" Value="{DynamicResource CodeBackgroundBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource CodeForegroundBrush}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="MinHeight" Value="42" />
      <Setter Property="Padding" Value="11,0" />
      <Setter Property="FontFamily"
              Value="SFMono-Regular, Cascadia Code, Noto Sans Mono CJK SC, Consolas, monospace" />
      <Setter Property="FontSize" Value="15" />
    </Style>
    <Style Selector="ComboBox">
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="NumericUpDown">
      <Setter Property="FontFeatures" Value="tnum" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="NumericUpDown.port-input">
      <Setter Property="Increment" Value="1" />
      <Setter Property="FormatString" Value="0" />
      <Setter Property="ParsingNumberStyle" Value="Integer" />
      <Setter Property="ShowButtonSpinner" Value="False" />
    </Style>
    <Style Selector="TextBox:focus, ComboBox:focus, NumericUpDown:focus">
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="TextBox:disabled, ComboBox:disabled, NumericUpDown:disabled">
      <Setter Property="Background" Value="{DynamicResource InputBrush}" />
      <Setter Property="Opacity" Value="0.5" />
    </Style>
    <Style Selector="edit|TextEditor.code-editor">
      <Setter Property="Background" Value="{DynamicResource CodeBackgroundBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource CodeForegroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource DarkModuleBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="18" />
      <Setter Property="FontFamily"
              Value="SFMono-Regular, Cascadia Code, Noto Sans Mono CJK SC, Consolas, monospace" />
      <Setter Property="FontSize" Value="14" />
    </Style>
    <Style Selector="edit|TextEditor.code-editor:focus-within">
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="edit|TextEditor.code-editor.embedded-editor">
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
    </Style>
    <Style Selector="edit|TextEditor.console-output">
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="Padding" Value="16" />
    </Style>
    <Style Selector="ListBoxItem">
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Margin" Value="0,2" />
    </Style>
    <Style Selector="ListBox.profile-grid ListBoxItem">
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Margin" Value="0" />
    </Style>
    <Style Selector="ListBox.proxy-groups ListBoxItem">
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Margin" Value="7,2" />
    </Style>
    <Style Selector="ListBox.node-list ListBoxItem">
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
    </Style>
    <Style Selector="ListBox.node-list ListBoxItem:pointerover /template/ ContentPresenter,
                     ListBox.node-list ListBoxItem:selected /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Border.node-row">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="Margin" Value="18,0" />
    </Style>
    <Style Selector="Border.node-row.selected">
      <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
    </Style>
    <Style Selector="Button.node-select">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="Padding" Value="10,7" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="RenderTransform" Value="translate(0px, 0px)" />
    </Style>
    <Style Selector="Button.node-select:pointerover">
      <Setter Property="RenderTransform" Value="translate(0px, 0px)" />
    </Style>
    <Style Selector="Button.node-select:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource SurfaceSubtleBrush}" />
    </Style>
    <Style Selector="Button.node-test">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="7" />
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="MinWidth" Value="56" />
      <Setter Property="Padding" Value="9,6" />
      <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="Button.node-test:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource SurfaceSubtleBrush}" />
    </Style>
    <Style Selector="TextBlock.node-delay">
      <Setter Property="Foreground" Value="{DynamicResource FaintTextBrush}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontFeatures" Value="tnum" />
    </Style>
    <Style Selector="Border.delay-badge">
      <Setter Property="Background" Value="{DynamicResource SurfaceSubtleBrush}" />
      <Setter Property="CornerRadius" Value="99" />
      <Setter Property="Padding" Value="8,3" />
      <Setter Property="MinWidth" Value="56" />
      <Setter Property="HorizontalAlignment" Value="Right" />
    </Style>
    <Style Selector="Border.delay-badge.fast">
      <Setter Property="Background" Value="{DynamicResource SuccessSoftBrush}" />
    </Style>
    <Style Selector="Border.delay-badge.medium">
      <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
    </Style>
    <Style Selector="Border.delay-badge.slow">
      <Setter Property="Background" Value="{DynamicResource DangerSoftBrush}" />
    </Style>
    <Style Selector="TextBlock.node-delay.fast">
      <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
    </Style>
    <Style Selector="TextBlock.node-delay.medium">
      <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="TextBlock.node-delay.slow">
      <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
    </Style>
    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource SurfaceSubtleBrush}" />
    </Style>
    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
    </Style>
    <Style Selector="ListBox.log-list ListBoxItem:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#0BFFFFFF" />
    </Style>
    <Style Selector="ListBox.log-list ListBoxItem:selected /template/ ContentPresenter">
      <Setter Property="Background" Value="#10FFFFFF" />
    </Style>
    <Style Selector="ListBox.log-list ListBoxItem">
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Border.log-row">
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="2,0,0,0" />
    </Style>
    <Style Selector="Border.log-row.warning">
      <Setter Property="BorderBrush" Value="#D5A56F" />
      <Setter Property="Background" Value="#0ED5A56F" />
    </Style>
    <Style Selector="Border.log-row.error, Border.log-row.fatal">
      <Setter Property="BorderBrush" Value="#D77E72" />
      <Setter Property="Background" Value="#0ED77E72" />
    </Style>
    <Style Selector="TextBlock.log-level">
      <Setter Property="FontFamily"
              Value="SFMono-Regular, Cascadia Code, Noto Sans Mono CJK SC, Consolas, monospace" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#8E857A" />
      <Setter Property="VerticalAlignment" Value="Top" />
    </Style>
    <Style Selector="TextBlock.log-level.system">
      <Setter Property="Foreground" Value="#B98261" />
    </Style>
    <Style Selector="TextBlock.log-level.trace, TextBlock.log-level.debug">
      <Setter Property="Foreground" Value="#8FA8C8" />
    </Style>
    <Style Selector="TextBlock.log-level.info">
      <Setter Property="Foreground" Value="#91AF95" />
    </Style>
    <Style Selector="TextBlock.log-level.warning">
      <Setter Property="Foreground" Value="#D5A56F" />
    </Style>
    <Style Selector="TextBlock.log-level.error, TextBlock.log-level.fatal">
      <Setter Property="Foreground" Value="#D77E72" />
    </Style>
    <Style Selector="Separator">
      <Setter Property="Background" Value="{DynamicResource CardBorderBrush}" />
    </Style>
    <Style Selector="ProgressBar">
      <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
      <Setter Property="Background" Value="{DynamicResource SurfaceSubtleBrush}" />
    </Style>
  </Application.Styles>
</Application>
